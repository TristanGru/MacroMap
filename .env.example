# EIA v2 API key (free, primary source for Brent/WTI prices with 30-day history)
# Register at https://www.eia.gov/opendata/ → Register → Get API Key
EIA_API_KEY=

# Vercel KV credentials (auto-populated by 'vercel env pull .env.local')
# Only needed for production — local dev uses in-memory store via lib/kv.ts
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Disruption threshold: GDELT article count to trigger state transitions
# Start at 10, tune after Step 0 GDELT analysis. See docs/gdelt-threshold-analysis.md
DISRUPTION_THRESHOLD=10

# Secret for /api/refresh-chokepoint auth header — any random string
# Must match CRON_SECRET in GitHub Actions secrets
# Protects POST-only /api/refresh-* endpoints.
CRON_SECRET=

# GDELT fixture mode — set to 'true' for local dev to skip live GDELT calls
# Remove or set to 'false' before deploying
NEXT_PUBLIC_USE_GDELT_FIXTURES=true

# Set after first Vercel deploy — add to GitHub Actions secrets, not .env.local
# VERCEL_POLL_URL=https://your-app.vercel.app

# ── v2: New data sources (all free tier) ────────────────────────────────────

# ACLED conflict events API (free with account registration)
# Register at https://acleddata.com/register/ — use your myACLED email + password
ACLED_EMAIL=
ACLED_PASSWORD=

# NASA FIRMS wildfire API (free, register at https://firms.modaps.eosdis.nasa.gov/api/map_key/)
FIRMS_MAP_KEY=

# FRED (Federal Reserve) API (free, register at https://fred.stlouisfed.org/docs/api/api_key.html)
# Provides: CPI, Food Index, Wheat, Copper, Henry Hub Gas, PPI
FRED_API_KEY=

# Oil Price API (free forever tier, no credit card)
# Register at https://oilpriceapi.com → Dashboard → API Key
OIL_PRICE_API_KEY=

# Trading Economics API (free tier — used for Baltic Dry Index)
# Register at https://tradingeconomics.com/api/ → Free tier
TRADING_ECONOMICS_KEY=

# USDA NASS QuickStats API (free, register at https://quickstats.nass.usda.gov/api)
# Provides: weekly corn + soybean crop condition ratings (% rated good/excellent)
# Only published during growing season (May–Nov); returns empty off-season
USDA_NASS_API_KEY=

# UN Comtrade Basic Individual API key (free registration)
# Provides: annual country trade products and partners for country profiles
UN_COMTRADE_API_KEY=
